# Copie para ~/.dbt/profiles.yml ou use DBT_PROFILES_DIR apontando para dbt-config/.dbt
# Ajuste host, user, password, dbname e schema (valores literais — sem env_var).

config:
  partial_parse: false

desafio_rmi_ds:
  target: dev
  outputs:
    dev:
      type: postgres
      host: localhost
      user: postgres
      password: postgres
      port: 5432
      dbname: desafio_rmi_ds
      schema: desafio_rmi_ds
      threads: 4

    prod:
      type: postgres
      host: localhost
      user: postgres
      password: postgres
      port: 5432
      dbname: desafio_rmi_ds
      schema: desafio_rmi_ds_prod
      threads: 4
